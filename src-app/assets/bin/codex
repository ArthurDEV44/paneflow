#!/usr/bin/env bash
# PaneFlow wrapper for OpenAI Codex CLI — bridges Codex lifecycle events to
# PaneFlow's IPC socket so the sidebar can track Codex's state.
#
# When launched inside a PaneFlow terminal, this script:
#   1. Detects the real `codex` binary on PATH (skipping itself)
#   2. Calls paneflow-hook session-start before launching Codex
#   3. Sets an EXIT trap for session-end (Codex has no SessionEnd event)
#   4. Passes -c features.codex_hooks=true to enable the hooks feature gate
#   5. Runs Codex with all original arguments preserved
#
# Outside PaneFlow (no PANEFLOW_SURFACE_ID), this is a transparent passthrough.
#
# Note: Codex hooks (UserPromptSubmit, PreToolUse, Stop) are configured via
# ~/.codex/hooks.json — installed/merged idempotently below.

set -euo pipefail

# ---------------------------------------------------------------------------
# Find the real codex binary (skip our own directory on PATH)
# ---------------------------------------------------------------------------
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLEAN_PATH="${PATH//$SELF_DIR:/}"
CLEAN_PATH="${CLEAN_PATH//:$SELF_DIR/}"
REAL_CODEX="$(PATH="$CLEAN_PATH" command -v codex 2>/dev/null || true)"

if [[ -z "$REAL_CODEX" ]]; then
    echo "paneflow: codex not found on PATH" >&2
    exit 127
fi

# ---------------------------------------------------------------------------
# Guard 1: Not inside PaneFlow — passthrough to real codex
# ---------------------------------------------------------------------------
if [[ -z "${PANEFLOW_SURFACE_ID:-}" ]]; then
    exec "$REAL_CODEX" "$@"
fi

# ---------------------------------------------------------------------------
# Guard 2: IPC socket unreachable — passthrough
# ---------------------------------------------------------------------------
SOCKET="${PANEFLOW_SOCKET_PATH:-}"
if [[ -z "$SOCKET" ]] || ! [[ -S "$SOCKET" ]]; then
    exec "$REAL_CODEX" "$@"
fi

# Quick reachability check: try connecting with 1s timeout.
# Prefer socat, fall back to nc -U, skip check if neither is available.
if command -v socat &>/dev/null; then
    if ! socat -u /dev/null "UNIX-CONNECT:${SOCKET},connect-timeout=1" 2>/dev/null; then
        exec "$REAL_CODEX" "$@"
    fi
elif command -v nc &>/dev/null; then
    if ! nc -z -w1 -U "$SOCKET" 2>/dev/null; then
        exec "$REAL_CODEX" "$@"
    fi
fi

# ---------------------------------------------------------------------------
# Export PID for stale session tracking
# ---------------------------------------------------------------------------
export PANEFLOW_CODEX_PID=$$

# ---------------------------------------------------------------------------
# Install PaneFlow hooks into ~/.codex/hooks.json (idempotent)
#
# Three events: UserPromptSubmit, PreToolUse, Stop.
# SessionStart/SessionEnd are handled by this wrapper directly (above/below).
# Codex has no Notification event (upstream gap).
# ---------------------------------------------------------------------------
CODEX_DIR="$HOME/.codex"
HOOKS_FILE="$CODEX_DIR/hooks.json"

# JSON-escape the hook directory path for safe embedding
ESCAPED_HOOK_DIR="${SELF_DIR//\\/\\\\}"
ESCAPED_HOOK_DIR="${ESCAPED_HOOK_DIR//\"/\\\"}"

# PaneFlow hooks template — the 3 events Codex dispatches that we need
read -r -d '' PANEFLOW_HOOKS << 'HOOKSTPL' || true
{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "__HOOK_DIR__/paneflow-hook prompt-submit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "__HOOK_DIR__/paneflow-hook tool-use",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "__HOOK_DIR__/paneflow-hook stop"
          }
        ]
      }
    ]
  }
}
HOOKSTPL

# Substitute the actual hook directory path
PANEFLOW_HOOKS="${PANEFLOW_HOOKS//__HOOK_DIR__/$ESCAPED_HOOK_DIR}"

mkdir -p "$CODEX_DIR"

if [[ ! -f "$HOOKS_FILE" ]] || [[ ! -s "$HOOKS_FILE" ]]; then
    # No existing hooks.json (or empty file) — write fresh PaneFlow hooks
    TMP_HOOKS=$(mktemp "$CODEX_DIR/.hooks.json.XXXXXX")
    printf '%s\n' "$PANEFLOW_HOOKS" > "$TMP_HOOKS"
    chmod 600 "$TMP_HOOKS"
    mv "$TMP_HOOKS" "$HOOKS_FILE"
elif command -v jq &>/dev/null; then
    # Merge: remove stale PaneFlow entries (idempotent), then inject fresh ones.
    # PaneFlow hooks are identified by commands containing "paneflow-hook".
    MERGED=$(jq -s '
      .[0] as $existing | .[1] as $pf |
      ($existing.hooks // {}) as $eh |
      ($pf.hooks // {}) as $ph |
      ([$eh, $ph] | map(keys) | add | unique) as $events |
      $existing + { "hooks":
        ( [ $events[] as $ev |
            # User entries for this event (filter out paneflow-hook commands)
            ( ($eh[$ev] // []) | map(
                { "matcher": .matcher,
                  "hooks": [ .hooks[] | select((.command? // "") | test("paneflow-hook") | not) ] }
              ) | map(select(.hooks | length > 0))
            ) as $user_entries |
            ( ($ph[$ev] // []) ) as $pf_entries |
            { ($ev): ($user_entries + $pf_entries) }
          ] | add // {} )
      }
    ' "$HOOKS_FILE" <(printf '%s\n' "$PANEFLOW_HOOKS") 2>/dev/null) || MERGED=""

    if [[ -n "$MERGED" ]]; then
        TMP_HOOKS=$(mktemp "$CODEX_DIR/.hooks.json.XXXXXX")
        printf '%s\n' "$MERGED" > "$TMP_HOOKS"
        chmod 600 "$TMP_HOOKS"
        mv "$TMP_HOOKS" "$HOOKS_FILE"
    fi
    # If jq merge failed, leave existing file untouched (safe)
fi
# No jq + file exists → skip merge entirely (safe fallback)

# ---------------------------------------------------------------------------
# Cleanup: send session-end on exit (Codex has no SessionEnd hook event)
# ---------------------------------------------------------------------------
HOOK_CMD="$SELF_DIR/paneflow-hook"

cleanup() {
    echo '{}' | "$HOOK_CMD" session-end 2>/dev/null || true
}
trap cleanup EXIT

# ---------------------------------------------------------------------------
# Notify PaneFlow that a Codex session is starting
# ---------------------------------------------------------------------------
echo '{}' | "$HOOK_CMD" session-start 2>/dev/null || true

# ---------------------------------------------------------------------------
# Launch Codex with hooks feature gate enabled.
# Not using exec — the EXIT trap must fire when Codex exits to send
# session-end (Codex has no SessionEnd event, unlike Claude Code).
# ---------------------------------------------------------------------------
CODEX_EXIT=0
"$REAL_CODEX" -c features.codex_hooks=true "$@" || CODEX_EXIT=$?
exit "$CODEX_EXIT"
