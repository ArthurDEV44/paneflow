<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    PaneFlow dev entitlements (US-023).

    Used for ad-hoc / local development signing only. Pass via
    `scripts/sign-macos.sh` with the entitlements flag pointing at
    this file when you need to attach a debugger (lldb / Xcode) to a
    signed .app on your own machine.

    DO NOT ship this file to users. A distribution build that carries
    get-task-allow=true is rejected at notarization with:
        "The executable requests the com.apple.security.get-task-allow
         entitlement, which is not allowed in distribution provisioning
         profiles."

    All keys mirror packaging/macos/paneflow.entitlements; the ONLY
    difference is the addition of get-task-allow.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <key>com.apple.security.get-task-allow</key>
    <true/>
</dict>
</plist>
